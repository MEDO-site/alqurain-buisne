{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item for sale (AC, Elevator parts, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["ac", "elevator", "spare_parts"] },
        "imageUrl": { "type": "string" },
        "specs": { "type": "object" },
        "stock": { "type": "integer" }
      },
      "required": ["name", "price", "category"]
    },
    "Service": {
      "title": "Service",
      "description": "A technical service (Maintenance, Installation)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["ac_maintenance", "elevator_maintenance", "general_technical"] },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Maintenance": {
      "title": "Maintenance Request",
      "description": "A request for a technical visit/maintenance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "service", "date", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Private user information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products for sale"
    },
    "services": {
      "schema": "Service",
      "description": "Collection of available technical services"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer product orders"
    },
    "maintenance": {
      "schema": "Maintenance",
      "description": "Service appointment maintenance requests"
    },
    "users/{userId}/private/info": {
      "schema": "UserProfile",
      "description": "Private user profile data"
    }
  }
}
